# .gitignore for AI Qaari Backend

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Model cache
models/
.cache/
transformers_cache/

# Logs
*.log
logs/

# Environment variables
.env
.env.local

# Temporary files
*.wav
*.mp3
*.m4a
temp/
tmp/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Large audio files (keep data structure, ignore content)
data/audio/*.mp3
data/audio/*.wav
!data/audio/.gitkeep

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# OS
Thumbs.db
